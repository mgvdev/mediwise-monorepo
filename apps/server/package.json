{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "hono": "catalog:",
    "@trpc/server": "catalog:",
    "@hono/trpc-server": "^0.4.0",
    "better-auth": "catalog:",
    "ai": "catalog:",
    "@ai-sdk/google": "^3.0.1",
    "@ai-sdk/devtools": "^0.0.2",
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@mediwise-monorepo/env": "workspace:*",
    "@mediwise-monorepo/api": "workspace:*",
    "@mediwise-monorepo/auth": "workspace:*",
    "@mediwise-monorepo/db": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "tsdown": "^0.16.5",
    "@mediwise-monorepo/config": "workspace:*"
  }
}
