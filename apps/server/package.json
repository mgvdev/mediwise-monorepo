{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.js"
	},
	"dependencies": {
		"@ai-sdk/devtools": "^0.0.2",
		"@ai-sdk/google": "^3.0.1",
		"@hono/trpc-server": "^0.4.0",
		"@mediwise-monorepo/api": "workspace:*",
		"@mediwise-monorepo/auth": "workspace:*",
		"@mediwise-monorepo/db": "workspace:*",
		"@mediwise-monorepo/env": "workspace:*",
		"@mediwise-monorepo/infrastructure": "workspace:*",
		"@trpc/server": "catalog:",
		"ai": "catalog:",
		"ai-sdk-ollama": "^3.0.1",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"typescript": "catalog:",
		"tsdown": "^0.16.5",
		"@mediwise-monorepo/config": "workspace:*"
	}
}
