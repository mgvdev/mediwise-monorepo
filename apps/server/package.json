{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.js"
	},
	"dependencies": {
		"@ai-sdk/devtools": "^0.0.2",
		"@ai-sdk/google": "^3.0.82",
		"@hono/trpc-server": "^0.4.2",
		"@mediwise-monorepo/api": "workspace:*",
		"@mediwise-monorepo/auth": "workspace:*",
		"@mediwise-monorepo/db": "workspace:*",
		"@mediwise-monorepo/env": "workspace:*",
		"@mediwise-monorepo/infrastructure": "workspace:*",
		"@trpc/server": "^11.17.0",
		"ai": "^6.0.206",
		"ai-sdk-ollama": "^3.8.7",
		"better-auth": "^1.6.19",
		"dotenv": "^17.4.2",
		"hono": "^4.12.25",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"typescript": "^6.0.3",
		"tsdown": "^0.16.8",
		"@mediwise-monorepo/config": "workspace:*"
	}
}
