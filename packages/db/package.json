  "devDependencies": {
    "typescript": "catalog:",
    "@mediwise-monorepo/config": "workspace:*"
  },
  "dependencies": {
    "mongoose": "^8.14.0",
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@mediwise-monorepo/env": "workspace:*"
  }
}
