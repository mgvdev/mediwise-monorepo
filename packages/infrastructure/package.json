{
	"name": "@mediwise-monorepo/infrastructure",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./appointments": {
			"default": "./src/appointments/index.ts"
		},
		"./appointments/*": {
			"default": "./src/appointments/*.ts"
		},
		"./exams": {
			"default": "./src/exams/index.ts"
		},
		"./exams/*": {
			"default": "./src/exams/*.ts"
		},
		"./interactions": {
			"default": "./src/interactions/index.ts"
		},
		"./interactions/*": {
			"default": "./src/interactions/*.ts"
		},
		"./jobs": {
			"default": "./src/jobs/index.ts"
		},
		"./jobs/*": {
			"default": "./src/jobs/*.ts"
		},
		"./prescriptions": {
			"default": "./src/prescriptions/index.ts"
		},
		"./prescriptions/*": {
			"default": "./src/prescriptions/*.ts"
		},
		"./practitioners": {
			"default": "./src/practitioners/index.ts"
		},
		"./practitioners/*": {
			"default": "./src/practitioners/*.ts"
		},
		"./reminders": {
			"default": "./src/reminders/index.ts"
		},
		"./reminders/*": {
			"default": "./src/reminders/*.ts"
		}
	},
	"scripts": {},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1069.0",
		"@mediwise-monorepo/db": "workspace:*",
		"@mediwise-monorepo/domain": "workspace:*",
		"@mediwise-monorepo/env": "workspace:*",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@mediwise-monorepo/config": "workspace:*",
		"typescript": "^6.0.3"
	}
}
