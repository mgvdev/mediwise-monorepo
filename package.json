{
	"name": "mediwise-monorepo",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.4.2",
			"zod": "^4.4.3",
			"typescript": "^6",
			"@types/bun": "^1.3.14",
			"hono": "^4.12.25",
			"@trpc/server": "^11.17.0",
			"better-auth": "^1.6.19",
			"ai": "^6.0.206",
			"@trpc/tanstack-react-query": "^11.17.0",
			"@trpc/client": "^11.17.0",
			"@tanstack/react-query": "^5.101.0",
			"@ai-sdk/react": "^3.0.208",
			"@better-auth/expo": "^1.6.19"
		}
	},
	"type": "module",
	"scripts": {
		"check": "oxlint --fix && oxfmt",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"prepare": "husky",
		"ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"dev:queue": "turbo -F queue dev",
		"dev:admin": "turbo -F admin-dashboard dev",
		"db:start": "turbo -F @mediwise-monorepo/db db:start",
		"db:watch": "turbo -F @mediwise-monorepo/db db:watch",
		"db:stop": "turbo -F @mediwise-monorepo/db db:stop",
		"db:down": "turbo -F @mediwise-monorepo/db db:down"
	},
	"dependencies": {
		"@mediwise-monorepo/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@mediwise-monorepo/config": "workspace:*",
		"@types/bun": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"turbo": "^2.9.18",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,jsx,tsx}": [
			"oxlint --fix",
			"oxfmt"
		],
		"*.{json,jsonc}": [
			"oxfmt"
		]
	},
	"packageManager": "bun@1.3.1"
}
