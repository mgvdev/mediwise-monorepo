{
	"name": "mediwise-monorepo",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^5",
			"@types/bun": "^1.3.4",
			"hono": "^4.8.2",
			"@trpc/server": "^11.7.2",
			"better-auth": "^1.4.9",
			"ai": "^6.0.3",
			"@trpc/tanstack-react-query": "^11.7.2",
			"@trpc/client": "^11.7.2",
			"@tanstack/react-query": "^5.90.12",
			"@ai-sdk/react": "^3.0.3",
			"@better-auth/expo": "^1.4.9"
		}
	},
	"type": "module",
	"scripts": {
		"check": "biome check --write .",
		"prepare": "husky",
		"ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"dev:queue": "turbo -F queue dev",
		"db:start": "turbo -F @mediwise-monorepo/db db:start",
		"db:watch": "turbo -F @mediwise-monorepo/db db:watch",
		"db:stop": "turbo -F @mediwise-monorepo/db db:stop",
		"db:down": "turbo -F @mediwise-monorepo/db db:down"
	},
	"dependencies": {
		"dotenv": "catalog:",
		"zod": "catalog:",
		"@mediwise-monorepo/env": "workspace:*"
	},
	"devDependencies": {
		"turbo": "^2.6.3",
		"@biomejs/biome": "^2.2.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"typescript": "catalog:",
		"@types/bun": "catalog:",
		"@mediwise-monorepo/config": "workspace:*"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.1"
}
